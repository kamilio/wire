{
  "name": "wire-vscode-extension",
  "publisher": "wire",
  "displayName": "Wire - Markdown Sync",
  "description": "Attach Notion, Google Docs, Slack, Gmail, Asana, ChatGPT, and Zoom resources as local Markdown you can sync from VS Code.",
  "version": "0.1.4",
  "type": "commonjs",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Productivity",
    "Other"
  ],
  "keywords": [
    "wire",
    "markdown",
    "sync",
    "notion",
    "google docs",
    "slack",
    "gmail",
    "asana",
    "chatgpt",
    "zoom",
    "documentation",
    "knowledge base",
    "agents"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kamilio/wire.git"
  },
  "homepage": "https://github.com/kamilio/wire#readme",
  "bugs": {
    "url": "https://github.com/kamilio/wire/issues"
  },
  "qna": false,
  "galleryBanner": {
    "color": "#111827",
    "theme": "dark"
  },
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:wire.initProject",
    "onCommand:wire.attachHere",
    "onCommand:wire.downloadHere",
    "onCommand:wire.previewUrl",
    "onCommand:wire.syncFile",
    "onCommand:wire.detachFile",
    "onCommand:wire.openResource",
    "onCommand:wire.syncDirectory",
    "onCommand:wire.authStatus",
    "onCommand:wire.authLogin",
    "onCommand:wire.authLogout",
    "onCommand:wire.compileAndReload"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "wire.initProject",
        "title": "Wire - Init Project",
        "category": "Wire",
        "icon": "$(database)"
      },
      {
        "command": "wire.attachHere",
        "title": "Wire - Attach",
        "category": "Wire",
        "icon": "$(plug)"
      },
      {
        "command": "wire.downloadHere",
        "title": "Wire - Download",
        "category": "Wire",
        "icon": "$(cloud-download)"
      },
      {
        "command": "wire.previewUrl",
        "title": "Wire - Preview",
        "category": "Wire",
        "icon": "$(preview)"
      },
      {
        "command": "wire.syncFile",
        "title": "Wire - Sync",
        "category": "Wire",
        "icon": "$(sync)"
      },
      {
        "command": "wire.detachFile",
        "title": "Wire - Detach",
        "category": "Wire",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "wire.openResource",
        "title": "Wire - Open",
        "category": "Wire",
        "icon": "$(globe)"
      },
      {
        "command": "wire.syncDirectory",
        "title": "Wire - Sync All",
        "category": "Wire",
        "icon": "$(sync)"
      },
      {
        "command": "wire.authStatus",
        "title": "Wire - Auth Status",
        "category": "Wire",
        "icon": "$(key)"
      },
      {
        "command": "wire.authLogin",
        "title": "Wire - Login",
        "category": "Wire",
        "icon": "$(sign-in)"
      },
      {
        "command": "wire.authLogout",
        "title": "Wire - Logout",
        "category": "Wire",
        "icon": "$(sign-out)"
      },
      {
        "command": "wire.compileAndReload",
        "title": "Wire - Compile and Reload",
        "category": "Wire",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "wire.attachHere",
          "when": "resourceScheme == file && explorerResourceIsFolder",
          "group": "2_wire@1"
        },
        {
          "command": "wire.downloadHere",
          "when": "resourceScheme == file && explorerResourceIsFolder",
          "group": "2_wire@2"
        },
        {
          "command": "wire.syncDirectory",
          "when": "resourceScheme == file && explorerResourceIsFolder",
          "group": "2_wire@3"
        },
        {
          "command": "wire.syncFile",
          "when": "resourceScheme == file && !explorerResourceIsFolder",
          "group": "2_wire@1"
        },
        {
          "command": "wire.detachFile",
          "when": "resourceScheme == file && !explorerResourceIsFolder",
          "group": "2_wire@2"
        },
        {
          "command": "wire.openResource",
          "when": "resourceScheme == file && !explorerResourceIsFolder",
          "group": "2_wire@3"
        }
      ],
      "editor/title": [
        {
          "command": "wire.syncFile",
          "when": "resourceScheme == file && resourceExtname == .md",
          "group": "navigation@1"
        },
        {
          "command": "wire.openResource",
          "when": "resourceScheme == file && resourceExtname == .md",
          "group": "navigation@2"
        }
      ],
      "commandPalette": [
        {
          "command": "wire.initProject"
        },
        {
          "command": "wire.attachHere"
        },
        {
          "command": "wire.downloadHere"
        },
        {
          "command": "wire.previewUrl"
        },
        {
          "command": "wire.syncFile"
        },
        {
          "command": "wire.detachFile"
        },
        {
          "command": "wire.openResource"
        },
        {
          "command": "wire.syncDirectory"
        },
        {
          "command": "wire.authStatus"
        },
        {
          "command": "wire.authLogin"
        },
        {
          "command": "wire.authLogout"
        },
        {
          "command": "wire.compileAndReload"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "node bump-version.mjs patch && npm run compile",
    "compile": "npm run build",
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test test/*.test.mjs",
    "check": "npm run typecheck && npm run build && npm test",
    "version:patch": "node bump-version.mjs patch",
    "version:minor": "node bump-version.mjs minor",
    "version:major": "node bump-version.mjs major"
  },
  "dependencies": {
    "provider-asana": "0.1.0",
    "provider-chatgpt": "0.1.0",
    "provider-gmail": "0.1.0",
    "provider-google-docs": "0.1.0",
    "provider-notion": "0.1.0",
    "provider-slack": "0.1.0",
    "provider-zoom": "0.1.0",
    "wire-core": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.3",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.25.12",
    "typescript": "^5.9.3"
  }
}
