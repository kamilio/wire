{
  "name": "wire-vscode-extension",
  "publisher": "wire",
  "displayName": "Wire",
  "description": "VSCode extension for Wire SDK resource sync.",
  "version": "0.1.0",
  "type": "commonjs",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:wire.attachHere",
    "onCommand:wire.downloadHere",
    "onCommand:wire.previewUrl",
    "onCommand:wire.syncFile",
    "onCommand:wire.detachFile",
    "onCommand:wire.openResource",
    "onCommand:wire.syncDirectory",
    "onCommand:wire.authStatus",
    "onCommand:wire.authLogin",
    "onCommand:wire.authLogout",
    "onCommand:wire.compileAndReload"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Wire",
      "properties": {
        "wire.auth.asanaCookiesFile": {
          "type": "string",
          "scope": "application",
          "description": "Netscape cookies file for Asana."
        },
        "wire.auth.chatgptCookiesFile": {
          "type": "string",
          "scope": "application",
          "description": "Netscape cookies file for ChatGPT."
        },
        "wire.auth.gmailCookiesFile": {
          "type": "string",
          "scope": "application",
          "description": "Netscape cookies file for Gmail."
        },
        "wire.auth.googleDocsCookiesFile": {
          "type": "string",
          "scope": "application",
          "description": "Netscape cookies file for Google Docs and Sheets."
        },
        "wire.auth.notionCookiesFile": {
          "type": "string",
          "scope": "application",
          "description": "Netscape cookies file for Notion."
        },
        "wire.auth.slackCookiesFile": {
          "type": "string",
          "scope": "application",
          "description": "Netscape cookies file for Slack."
        },
        "wire.auth.zoomCookiesFile": {
          "type": "string",
          "scope": "application",
          "description": "Netscape cookies file for Zoom."
        },
        "wire.google.credentialsFile": {
          "type": "string",
          "scope": "application",
          "description": "Google OAuth credentials JSON file."
        },
        "wire.google.tokenFile": {
          "type": "string",
          "scope": "application",
          "description": "Google OAuth token JSON file."
        }
      }
    },
    "commands": [
      {
        "command": "wire.attachHere",
        "title": "Attach URL Here",
        "category": "Wire",
        "icon": "$(plug)"
      },
      {
        "command": "wire.downloadHere",
        "title": "Download URL Here",
        "category": "Wire",
        "icon": "$(cloud-download)"
      },
      {
        "command": "wire.previewUrl",
        "title": "Preview URL",
        "category": "Wire",
        "icon": "$(preview)"
      },
      {
        "command": "wire.syncFile",
        "title": "Sync File",
        "category": "Wire",
        "icon": "$(sync)"
      },
      {
        "command": "wire.detachFile",
        "title": "Detach File",
        "category": "Wire",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "wire.openResource",
        "title": "Open Resource",
        "category": "Wire",
        "icon": "$(globe)"
      },
      {
        "command": "wire.syncDirectory",
        "title": "Sync Directory",
        "category": "Wire",
        "icon": "$(sync)"
      },
      {
        "command": "wire.authStatus",
        "title": "Auth Status",
        "category": "Wire",
        "icon": "$(key)"
      },
      {
        "command": "wire.authLogin",
        "title": "Login",
        "category": "Wire",
        "icon": "$(sign-in)"
      },
      {
        "command": "wire.authLogout",
        "title": "Logout",
        "category": "Wire",
        "icon": "$(sign-out)"
      },
      {
        "command": "wire.compileAndReload",
        "title": "Compile and Reload",
        "category": "Wire",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "wire.attachHere",
          "when": "resourceScheme == file && explorerResourceIsFolder",
          "group": "2_wire@1"
        },
        {
          "command": "wire.downloadHere",
          "when": "resourceScheme == file && explorerResourceIsFolder",
          "group": "2_wire@2"
        },
        {
          "command": "wire.syncDirectory",
          "when": "resourceScheme == file && explorerResourceIsFolder",
          "group": "2_wire@3"
        },
        {
          "command": "wire.syncFile",
          "when": "resourceScheme == file && !explorerResourceIsFolder",
          "group": "2_wire@1"
        },
        {
          "command": "wire.detachFile",
          "when": "resourceScheme == file && !explorerResourceIsFolder",
          "group": "2_wire@2"
        },
        {
          "command": "wire.openResource",
          "when": "resourceScheme == file && !explorerResourceIsFolder",
          "group": "2_wire@3"
        }
      ],
      "editor/title": [
        {
          "command": "wire.syncFile",
          "when": "resourceScheme == file && resourceExtname == .md",
          "group": "navigation@1"
        },
        {
          "command": "wire.openResource",
          "when": "resourceScheme == file && resourceExtname == .md",
          "group": "navigation@2"
        }
      ],
      "commandPalette": [
        {
          "command": "wire.attachHere"
        },
        {
          "command": "wire.downloadHere"
        },
        {
          "command": "wire.previewUrl"
        },
        {
          "command": "wire.syncFile"
        },
        {
          "command": "wire.detachFile"
        },
        {
          "command": "wire.openResource"
        },
        {
          "command": "wire.syncDirectory"
        },
        {
          "command": "wire.authStatus"
        },
        {
          "command": "wire.authLogin"
        },
        {
          "command": "wire.authLogout"
        },
        {
          "command": "wire.compileAndReload"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "node bump-version.mjs patch && npm run compile",
    "compile": "npm run build",
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test test/*.test.mjs",
    "check": "npm run typecheck && npm run build && npm test",
    "version:patch": "node bump-version.mjs patch",
    "version:minor": "node bump-version.mjs minor",
    "version:major": "node bump-version.mjs major"
  },
  "dependencies": {
    "provider-asana": "0.1.0",
    "provider-chatgpt": "0.1.0",
    "provider-gmail": "0.1.0",
    "provider-google-docs": "0.1.0",
    "provider-notion": "0.1.0",
    "provider-slack": "0.1.0",
    "provider-zoom": "0.1.0",
    "wire-core": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.3",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.25.12",
    "typescript": "^5.9.3"
  }
}
