{
  "name": "@kamilio/wire",
  "version": "0.1.1",
  "description": "Attach Notion, Google Docs, Slack, Gmail, Asana, ChatGPT, and Zoom resources as local Markdown you can sync.",
  "keywords": [
    "markdown",
    "sync",
    "notion",
    "google-docs",
    "slack",
    "gmail",
    "asana",
    "chatgpt",
    "zoom",
    "mcp",
    "cli",
    "agent-tools"
  ],
  "type": "module",
  "bin": {
    "wire": "bin/wire.mjs",
    "wire-mcp": "bin/wire-mcp.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kamilio/wire.git",
    "directory": "packages/wire"
  },
  "bugs": {
    "url": "https://github.com/kamilio/wire/issues"
  },
  "homepage": "https://github.com/kamilio/wire",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js"
    }
  },
  "files": [
    "README.md",
    "bin",
    "dist",
    "src"
  ],
  "bundledDependencies": [
    "ajv",
    "commander",
    "fast-deep-equal",
    "fast-string-truncated-width",
    "fast-string-width",
    "fast-wrap-ansi",
    "fast-uri",
    "ignore",
    "jose",
    "jsonc-parser",
    "json-schema-traverse",
    "pct-encode",
    "provider-asana",
    "provider-chatgpt",
    "provider-gmail",
    "provider-google-docs",
    "provider-notion",
    "provider-slack",
    "provider-zoom",
    "require-from-string",
    "sisteransi",
    "smol-toml",
    "tiny-stdio-mcp-server",
    "toolcraft",
    "toolcraft-schema",
    "uri-template",
    "uri-template-lite",
    "wire-core",
    "yaml"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev-link": "npm link",
    "prepack": "cp ../../README.md README.md && rm -rf node_modules && mkdir -p node_modules && for package in provider-asana provider-chatgpt provider-gmail provider-google-docs provider-notion provider-slack provider-zoom wire-core; do cp -R ../$package node_modules/$package; done && for package in ajv commander fast-deep-equal fast-string-truncated-width fast-string-width fast-wrap-ansi fast-uri ignore jose jsonc-parser json-schema-traverse pct-encode require-from-string sisteransi smol-toml tiny-stdio-mcp-server toolcraft toolcraft-schema uri-template uri-template-lite yaml; do cp -R ../../node_modules/$package node_modules/$package; done",
    "postpack": "rm -rf node_modules README.md",
    "test": "node --test --test-concurrency=1 test/**/*.test.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run typecheck && npm run build && npm test"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "commander": "^14.0.3",
    "fast-deep-equal": "^3.1.3",
    "fast-string-truncated-width": "^3.0.3",
    "fast-string-width": "^3.0.2",
    "fast-uri": "^3.0.1",
    "fast-wrap-ansi": "^0.2.0",
    "ignore": "^5.3.2",
    "jose": "^6.1.2",
    "json-schema-traverse": "^1.0.0",
    "jsonc-parser": "^3.3.1",
    "pct-encode": "^1.0.3",
    "provider-asana": "0.1.0",
    "provider-chatgpt": "0.1.0",
    "provider-gmail": "0.1.0",
    "provider-google-docs": "0.1.0",
    "provider-notion": "0.1.0",
    "provider-slack": "0.1.0",
    "provider-zoom": "0.1.0",
    "require-from-string": "^2.0.2",
    "sisteransi": "^1.0.5",
    "smol-toml": "^1.3.0",
    "tiny-stdio-mcp-server": "^0.1.0",
    "toolcraft": "^0.0.83",
    "toolcraft-schema": "0.0.83",
    "uri-template": "^2.0.0",
    "uri-template-lite": "^23.4.0",
    "wire-core": "0.1.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^22.19.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "bundleDependencies": [
    "ajv",
    "commander",
    "fast-deep-equal",
    "fast-string-truncated-width",
    "fast-string-width",
    "fast-wrap-ansi",
    "fast-uri",
    "ignore",
    "jose",
    "jsonc-parser",
    "json-schema-traverse",
    "pct-encode",
    "provider-asana",
    "provider-chatgpt",
    "provider-gmail",
    "provider-google-docs",
    "provider-notion",
    "provider-slack",
    "provider-zoom",
    "require-from-string",
    "sisteransi",
    "smol-toml",
    "tiny-stdio-mcp-server",
    "toolcraft",
    "toolcraft-schema",
    "uri-template",
    "uri-template-lite",
    "wire-core",
    "yaml"
  ]
}
